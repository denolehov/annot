+
+/* Wider gutter for diff mode */
+.content.diff-mode .gutter {
+	width: 90px;
+	display: flex;
+	justify-content: flex-end;
+	gap: 0;
+}
+
+/* Adjust add button position for diff mode */
+.content.diff-mode .add-btn {
+	left: 81px;
+}
+
+/* Diff gutter shows old | new line numbers */
+.diff-gutter-old,
+.diff-gutter-new {
+	display: inline-block;
+	width: 3.5ch;
+	text-align: right;
+}
+
+.diff-gutter-old {
+	color: var(--text-muted);
+}
+
+.diff-gutter-new {
+	margin-left: 8px;
+	color: var(--text-muted);
+}
+
+/* Added lines (green) */
+.line.diff-added {
+	background-color: rgba(34, 197, 94, 0.1);
+}
+
+.line.diff-added:hover {
+	background-color: rgba(34, 197, 94, 0.15);
+}
+
+.line.diff-added .diff-gutter-new {
+	color: rgb(34, 197, 94);
+}
+
+/* Deleted lines (red) */
+.line.diff-deleted {
+	background-color: rgba(239, 68, 68, 0.1);
+}
+
+.line.diff-deleted:hover {
+	background-color: rgba(239, 68, 68, 0.15);
+}
+
+.line.diff-deleted .diff-gutter-old {
+	color: rgb(239, 68, 68);
+}
+
+/* Header lines (dimmed) */
+.line.diff-header {
+	background-color: var(--bg-panel);
+	color: var(--text-muted);
+}
+
+.line.diff-header .gutter {
+	color: var(--text-muted);
+}
+
+.line.diff-header .code {
+	font-weight: 500;
+}
+
+/* Context lines - no special styling, inherit defaults */
+.line.diff-context {
+	/* Default styling */
