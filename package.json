{
  "name": "annot",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/copy-excalidraw-fonts.js",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "demo": "tauri dev -- -- $PWD/test-fixtures/sample.md",
    "demo:diff": "tauri dev -- -- $PWD/test-fixtures/sample.diff",
    "demo:large": "tauri dev -- -- $PWD/test-fixtures/large.md",
    "demo:portals": "tauri dev -- -- $PWD/test-fixtures/portals.md",
    "generate:large": "bash scripts/generate-large-md.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "install:local": "ln -sf $PWD/src-tauri/target/release/bundle/macos/annot.app/Contents/MacOS/annot ~/.local/bin/annot && echo 'Installed annot to ~/.local/bin/annot'"
  },
  "license": "MIT",
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@excalidraw/mermaid-to-excalidraw": "^2.0.0",
    "@floating-ui/dom": "^1.7.4",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tiptap/core": "^3.14.0",
    "@tiptap/extension-placeholder": "^3.14.0",
    "@tiptap/pm": "^3.14.0",
    "@tiptap/starter-kit": "^3.14.0",
    "@tiptap/suggestion": "^3",
    "fuse.js": "^7.1.0",
    "mermaid": "^11.12.2",
    "panzoom": "^9.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.9",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^27.3.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.0.16"
  },
  "packageManager": "pnpm@8.10.2+sha1.e0b68270e89c817ff88b7be62466a2128c53af02"
}
